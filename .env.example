# Copy to .env for local dev. For PythonAnywhere prod, set these in the
# "Environment variables" section of the Web tab (NOT a .env file —
# the WSGI worker doesn't auto-load .env).

OPENAI_API_KEY=sk-replace-me
OPENAI_MODEL=gpt-4o-mini
APP_USERNAME=admin
APP_PASSWORD=replace-with-strong-password
FLASK_SECRET_KEY=replace-with-random-hex-32-bytes
